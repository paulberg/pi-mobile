# Required
BRIDGE_AUTH_TOKEN=change-me

# Optional
# Leave BRIDGE_HOST unset for localhost-only development.
# For direct phone access without a reverse proxy, set it to your laptop's
# Tailscale IPv4 (for example: 100.x.y.z).
# BRIDGE_HOST=100.x.y.z
BRIDGE_PORT=8787
BRIDGE_LOG_LEVEL=info
BRIDGE_PROCESS_IDLE_TTL_MS=300000
BRIDGE_RECONNECT_GRACE_MS=30000
BRIDGE_ENABLE_HEALTH_ENDPOINT=true
# BRIDGE_SESSION_DIR=/home/your-user/.pi/agent/sessions
