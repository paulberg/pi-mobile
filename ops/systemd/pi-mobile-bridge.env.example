# Required
PI_MOBILE_REPO_DIR=/home/your-user/repos/pi-mobile
BRIDGE_AUTH_TOKEN=change-me

# Optional overrides
BRIDGE_PORT=8787
BRIDGE_LOG_LEVEL=info
BRIDGE_ENABLE_HEALTH_ENDPOINT=true
# BRIDGE_SESSION_DIR=/home/your-user/.pi/agent/sessions
# BRIDGE_HOST=100.x.y.z

# If BRIDGE_HOST is omitted, the systemd launcher resolves the current
# Tailscale IPv4 automatically. For a non-Tailscale local-only service,
# set BRIDGE_HOST=127.0.0.1 explicitly.
